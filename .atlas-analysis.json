  "keyFeatures": [
    "MLX inference on Apple Silicon GPU via unified memory",
    "Word-level timestamps via wav2vec2 forced alignment",
    "Speaker diarization via pyannote-audio",
    "Voice Activity Detection (VAD) with pyannote or silero backends",
    "Support for 30+ languages",
    "Simple short model names auto-mapped to mlx-community HF repos",
    "Both CLI and Python API interfaces",
    "Multiple output formats: SRT, VTT, TXT, TSV, JSON"
  ],
  "publicApiSurface": [
